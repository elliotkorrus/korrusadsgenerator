# Port (Railway sets this automatically — leave blank locally)
PORT=3002

# Optional: MANUS webhook URL for live Meta Ads Manager uploads
# When set, "Send to Meta" will POST ad payloads to MANUS for browser automation
# When unset, the button shows you the payload but does not submit
MANUS_WEBHOOK_URL=

# Optional: Node environment (Railway sets NODE_ENV=production automatically)
NODE_ENV=development
